{
  "name": "jige-ui",
  "type": "module",
  "version": "0.33.1",
  "private": false,
  "description": "a solidjs component library",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/build.d.ts",
      "solid": "./dist/build.jsx",
      "default": "./dist/build.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "solid": "./dist/*/index.jsx",
      "default": "./dist/*/index.js"
    }
  },
  "main": "dist/build.js",
  "module": "dist/build.js",
  "types": "dist/build.d.ts",
  "typesVersions": {},
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build-dev": "cross-env DEV_MODE=true tsup",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "@tanstack/solid-table": "^8.21.3",
    "chart.js": "^4.4.9",
    "jige-core": "workspace:*",
    "solid-js": "^1.9.7"
  },
  "dependencies": {
    "@solid-primitives/bounds": "^0.1.0",
    "@solid-primitives/refs": "^1.1.1",
    "esday": "^0.4.1",
    "oklch-colors": "^0.0.1",
    "solid-tiny-context": "^0.0.2"
  },
  "devDependencies": {
    "@iconify-json/fluent": "^1.2.26",
    "browserslist": "^4.25.1",
    "cross-env": "^7.0.3",
    "esbuild-plugin-inline-import": "^1.1.0",
    "esbuild-plugin-solid": "^0.6.0",
    "lightningcss": "^1.30.1",
    "sass": "^1.89.2",
    "stylelint": "^16.21.1",
    "stylelint-order": "^7.0.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.5.4",
    "unplugin-icons": "^22.1.0",
    "jige-utils": "workspace:*"
  },
  "browser": {
    "./dist/server.js": "./dist/index.js"
  }
}
