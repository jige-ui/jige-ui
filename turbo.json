{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "jige-ui#build-dev": {
      "inputs": ["src/**/*.tsx", "src/**/*.scss"],
      "outputs": ["dist/**"],
      "dependsOn": ["jige-core#build"],
      "cache": false
    },
    "jige-core#build": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
